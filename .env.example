# =============================================================================
# Directioner Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# Discord Configuration
# =============================================================================
# Get your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord application ID
DISCORD_APPLICATION_ID=your_application_id_here

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: mock, groq, openai-compatible
DIRECTIONER_LLM_PROVIDER=mock

# API Key for external providers (Groq, OpenAI, etc.)
# Get your key from https://console.groq.com/keys or your OpenAI dashboard
DIRECTIONER_LLM_API_KEY=

# Model to use (for Groq: mixtral-8x7b-32768, llama-3.1-70b-versatile, etc.)
DIRECTIONER_LLM_MODEL=llama-3.1-70b-versatile

# Base URL for OpenAI-compatible APIs
DIRECTIONER_LLM_BASE_URL=

# =============================================================================
# Memory & Storage Configuration
# =============================================================================
# Enable/disable memory features
DIRECTIONER_MEMORY_ENABLED=true

# Maximum conversation turns to remember
DIRECTIONER_MEMORY_MAX_TURNS=200

# Number of turns to retrieve for context
DIRECTIONER_MEMORY_RETRIEVAL_TURNS=8

# Local storage path (leave empty for no persistence)
DIRECTIONER_MEMORY_PERSIST_PATH=./data/memory/turns.jsonl

# =============================================================================
# Supabase Configuration (Optional - for distributed deployments)
# =============================================================================
# Enable Supabase for cloud memory storage
DIRECTIONER_MEMORY_USE_SUPABASE=false

# Get these from your Supabase project settings
DIRECTIONER_SUPABASE_URL=https://your-project.supabase.co
DIRECTIONER_SUPABASE_KEY=your_supabase_anon_key_here

# =============================================================================
# Performance & Scaling Configuration
# =============================================================================
# Maximum concurrent conversations (default: 100000)
DIRECTIONER_MAX_CONVERSATIONS=100000

# Per-guild conversation limit (default: 10000)
DIRECTIONER_MAX_PER_GUILD=10000

# Per-channel conversation limit (default: 1000)
DIRECTIONER_MAX_PER_CHANNEL=1000

# Idle timeout in seconds (default: 3600 = 1 hour)
DIRECTIONER_IDLE_TIMEOUT=3600

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Requests per user per minute (default: 60)
DIRECTIONER_RATE_LIMIT_USER=60

# Requests per channel per minute (default: 300)
DIRECTIONER_RATE_LIMIT_CHANNEL=300

# Requests per guild per minute (default: 1000)
DIRECTIONER_RATE_LIMIT_GUILD=1000

# =============================================================================
# Application Settings
# =============================================================================
# App name
DIRECTIONER_APP_NAME=directioner

# Environment (development, staging, production)
DIRECTIONER_ENVIRONMENT=development

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DIRECTIONER_LOG_LEVEL=INFO

# =============================================================================
# Discord Gateway Configuration
# =============================================================================
# Number of shards (0 = auto)
DISCORD_SHARD_COUNT=0

# Compress gateway traffic
DISCORD_COMPRESSED=false

# Use ETF serialization (faster but less compatible)
DISCORD_USE_ETF=false

# Register global slash commands
DISCORD_REGISTER_GLOBAL_COMMANDS=false
