#===============================================================================
# Directioner Environment Configuration
#
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#===============================================================================

#------------------------------------------------------------------------------
# Required Settings
#------------------------------------------------------------------------------

# Discord Bot Token
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Groq API Key for LLM
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

#------------------------------------------------------------------------------
# Optional: Supabase (Long-term Memory)
#------------------------------------------------------------------------------

# Enable Supabase for persistent memory storage
# DIRECTIONER_MEMORY_USE_SUPABASE=false

# Supabase Project URL
# SUPABASE_URL=https://your-project.supabase.co

# Supabase API Key
# SUPABASE_KEY=your_supabase_anon_key_here

#------------------------------------------------------------------------------
# Optional: Voice Settings
#------------------------------------------------------------------------------

# Parakeet Model Path (for ONNX inference, faster than NeMo)
# PARAKEET_MODEL_PATH=C:\parakeet-onnx

# Audio Configuration
# AUDIO_SAMPLE_RATE=48000
# AUDIO_CHANNELS=2

# Voice Activity Detection
# VAD_THRESHOLD=0.5
# VAD_SILENCE_CHUNKS=20

# Wake Word
# WAKEWORD_MODEL=hey_jarvis
# WAKEWORD_THRESHOLD=0.5

#------------------------------------------------------------------------------
# Optional: Performance
#------------------------------------------------------------------------------

# Enable Hugging Face transfer for faster model downloads
# HF_HUB_ENABLE_HF_TRANSFER=1

# PyTorch CUDA settings
# CUDA_VISIBLE_DEVICES=0

#------------------------------------------------------------------------------
# Optional: Paths
#------------------------------------------------------------------------------

# Base directory for tool access
# DIRECTIONER_TOOL_BASE_DIR=.

# Memory persistence path
# DIRECTIONER_MEMORY_PERSIST_PATH=./data/memory.json

#------------------------------------------------------------------------------
# Optional: Debug
#------------------------------------------------------------------------------

# Enable debug logging
# DIRECTIONER_DEBUG=false

# Log level
# LOG_LEVEL=INFO
